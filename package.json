{
  "name": "novadash",
  "version": "1.0.0",
  "description": "NovaDash - Advanced Desktop Widget Engine. A modern, beautiful desktop widget app with 44+ tools.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "set NODE_ENV=development && electron .",
    "build": "electron-builder",
    "pack": "electron-builder --dir",
    "publish": "electron-builder --win --publish always",
    "release": "electron-builder --win --publish always"
  },
  "author": "@werlist99",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.7.3",
    "node-fetch": "^2.7.0",
    "systeminformation": "^5.21.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.novadash.app",
    "productName": "NovaDash",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "publisherName": "@werlist99"
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NovaDash",
      "perMachine": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "werlist99",
        "repo": "NovaDash",
        "releaseType": "release"
      }
    ]
  }
}
